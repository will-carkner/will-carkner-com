---
import Layout from '../layouts/Layout.astro'
import Card from '../components/Card.astro'
import Section from '../components/Section.astro'
import ArticleDisplay from '../components/ArticleDisplay.astro'
import { getPosts } from '../utils/funcs'
import Project from '../components/Project.astro'

import artData from '../../public/daily-art.json'

const cachedDate = new Date(artData.cachedAt)
const now = new Date()
const diffMs = now.getTime() - cachedDate.getTime()
const diffHours = Math.floor(diffMs / (1000 * 60 * 60))

const lastUpdated =
  diffHours < 1
    ? 'last changed less than an hour ago'
    : `last changed ${diffHours} hour${diffHours === 1 ? '' : 's'} ago`

const artLines = artData.text.split('\n')
const artArtist = artLines[0]?.trim()
const artTitle = artLines.slice(1).join(' ').trim()

const posts = (await getPosts()).slice(0, 3)
---

<Layout
  title="Will Carkner"
  description="Will Carkner — 19-year-old engineering student in Dublin building Syncra and thinking about the global energy grid."
>
  <h1 class="sr-only">Will Carkner</h1>
  <!-- BODY -->
  <Section>
    <div class="grid w-full grid-cols-1 gap-8 md:flex-row md:flex">
      <!-- ABOUT ME -->
      <div class="md:flex-1 space-y-8">
        <div
          class="rounded-xl bg-gradient-to-r animate-gradient-x from-blue-600 via-purple-600 to-violet-600 p-0.5"
        >
          <Card class="items-left !border-none !shadow-none">
            <div class="flex-col text-left space-y-4 flex">
              <div class="flex flex-row space-x-4 items-center">
                <img
                  alt="Will Carkner"
                  src="will-c.jpg"
                  class="w-24 h-24 object-cover rounded-lg"
                />
                <div class="flex flex-col text-left">
                  <h2 class="font-mono">will</h2>
                  <h2 class="font-mono">carkner</h2>
                </div>
              </div>
              <p class="text-gray-400 font-mono bold-slate-p text-justify">
                I'm a 19 year old <b> engineering</b> student, based in Dublin. I
                <b>love</b> to build stuff!
              </p><p class="text-gray-400 font-mono bold-slate-p text-justify">
                I am currently building <b>syncra</b>, making fancy power strips to help companies stop paying for waste.
              </p>
              <p class="text-gray-400 font-mono bold-slate-p text-justify">
                I believe energy is the <b
                  >most important resource of our time.
                </b> I'm thinking about how the global grid <b>evolves</b> to meet
                demand.
              </p>
            </div>
          </Card>
        </div>

        <!-- Writing -->
        <ArticleDisplay home={true} title="Writing" posts={posts} />

        <!-- Records -->
        <Card>
          <div class="flex flex-row flex-wrap gap-3 items-center justify-center max-w-[17rem] mx-auto">
            {
              [
                {
                  title: 'Led Zeppelin IV',
                  artist: 'Led Zeppelin',
                  image: 'records/led-zeppelin-iv.jpg',
                  wiki: 'https://en.wikipedia.org/wiki/Led_Zeppelin_IV',
                },
                {
                  title: "Can't Stop",
                  artist: 'Red Hot Chili Peppers',
                  image: 'records/cant-stop.jpg',
                  wiki: 'https://en.wikipedia.org/wiki/Can%27t_Stop_(Red_Hot_Chili_Peppers_song)',
                },
                {
                  title: 'Abbey Road',
                  artist: 'The Beatles',
                  image: 'records/abbey-road.jpg',
                  wiki: 'https://en.wikipedia.org/wiki/Abbey_Road',
                },
                {
                  title: 'Romance',
                  artist: 'Fontaines D.C.',
                  image: 'records/romance.jpg',
                  wiki: 'https://en.wikipedia.org/wiki/Romance_(Fontaines_D.C._album)',
                },
                {
                  title: 'Kind of Blue',
                  artist: 'Miles Davis',
                  image: 'records/kind-of-blue.jpg',
                  wiki: 'https://en.wikipedia.org/wiki/Kind_of_Blue',
                },
              ].map((record) => (
                <a href={record.wiki} target="_blank" rel="noopener noreferrer" class="no-underline group/record">
                  <div class="relative w-16 h-16 sm:w-20 sm:h-20 hover:scale-110 duration-300">
                    <div class="absolute inset-0 rounded-full bg-gray-900 border-2 border-gray-700 overflow-hidden shadow-lg group-hover/record:animate-spin-slow">
                      <div class="absolute inset-[4px] rounded-full overflow-hidden">
                        <img
                          src={record.image}
                          alt={`${record.title} by ${record.artist}`}
                          class="w-full h-full object-cover"
                        />
                      </div>
                      <div class="absolute inset-0 rounded-full border-[2px] border-gray-800/60" />
                      <div class="absolute inset-[38%] rounded-full bg-gray-900 border border-gray-600" />
                      <div class="absolute inset-[44%] rounded-full bg-gray-700" />
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
          <p class="font-mono text-gray-400 font-bold text-sm mt-2">my record collection</p>
        </Card>

        <!-- Contact -->
        <div
          class="rounded-xl bg-gradient-to-r animate-gradient-x from-blue-600 via-purple-600 to-violet-600 p-0.5"
        >
          <Card class="space-y-2 !border-none !shadow-none">
            <p class="font-mono text-gray-400 bold-slate-p">
              if any of what you see here seems interesting, i'd <b>love</b> to hear
              from you!
            </p>
            <div class="flex flex-row space-x-4">
              {
                [
                  {
                    text: '/github',
                    href: 'https://github.com/will-carkner',
                  },
                  {
                    text: '/x',
                    href: 'https://x.com/carknerwill',
                  },
                  {
                    text: '/insta',
                    href: 'https://www.instagram.com/_willcarkner/',
                  },
                  {
                    text: '/mail',
                    href: 'mailto:will@willcarkner.com',
                  },
                ].map((item) => (
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:duration-300 font-mono no-underline hover:underline hover:scale-110"
                  >
                    {item.text}
                  </a>
                ))
              }
            </div>
            <a
              class="text-white font-mono font-bold no-underline hover:text-sky-400 text-base hover:underline"
              href="/blog/contact"
            >
              learn more
            </a>
          </Card>
        </div>

        <Card>
          <div class="space-y-4">
            <p class="text-gray-400 font-mono bold-slate-p text-left">
              Do not go gentle into that good night,<br />
              Old age should burn and rave at close of day;<br />
              Rage, rage against the dying of the light.
            </p>
            <p class="text-gray-400 font-mono bold-slate-p text-left">
              Though wise men at their end know dark is right, <br />
              Because their words had forked no lightning they <br />
              Do not go gentle into that good night.
            </p>
            <div id="full-poem-text" class="hidden space-y-4">
              <p class="text-gray-400 font-mono bold-slate-p text-left">
                Good men, the last wave by, crying how bright <br />
                Their frail deeds might have danced in a green bay,<br />
                Rage, rage against the dying of the light.
              </p>
              <p class="text-gray-400 font-mono bold-slate-p text-left">
                Wild men who caught and sang the sun in flight,<br />
                And learn, too late, they grieved it on its way,<br />
                Do not go gentle into that good night.
              </p>
              <p class="text-gray-400 font-mono bold-slate-p text-left">
                Grave men, near death, who see with blinding sight<br />
                Blind eyes could blaze like meteors and be gay,<br />
                Rage, rage against the dying of the light.
              </p>
              <p class="text-gray-400 font-mono bold-slate-p text-left">
                And you, my father, there on the sad height,<br />
                Curse, bless, me now with your fierce tears, I pray.<br />
                Do not go gentle into that good night.<br />
                Rage, rage against the dying of the light.
              </p>
            </div>
            <div class="flex flex-col space-y-2">
              <p class="text-gray-400 font-mono text-left">- dylan thomas</p>
              <button
                type="button"
                class="text-white font-mono font-bold bg-transparent border-none p-0 text-base text-left w-fit hover:text-sky-400 hover:cursor-pointer hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-400 rounded"
                id="full-poem"
                aria-expanded="false"
                aria-controls="full-poem-text"
              >
                view full poem
              </button>
              <script>
                const fullPoem = document.getElementById('full-poem')!
                const fullPoemText = document.getElementById('full-poem-text')!
                let hidden = true
                fullPoem.addEventListener('click', () => {
                  hidden = !hidden
                  fullPoemText.classList.toggle('hidden', hidden)
                  fullPoemText.classList.toggle('visible', !hidden)
                  fullPoem.setAttribute('aria-expanded', String(!hidden))
                  fullPoem.innerText = hidden
                    ? 'view full poem'
                    : 'hide full poem'
                })
              </script>
            </div>
          </div>
        </Card>
      </div>

      <!-- SECOND COLUMN -->
      <div class="md:flex-1 space-y-8">
        <!-- Projects -->
        <Card class="space-y-4">
          <!-- <h4>Work</h4> -->
          <div class="flex flex-col space-y-4 justify-end">
            {
              [
                {
                  title: 'Syncra',
                  tags: ['IoT', 'Hardware', 'Platform'],
                  image: 'syncra.png',
                  url: 'https://syncra.ie',
                  class: 'aspect-[3/2]',
                },
                {
                  title: 'Lumindt',
                  tags: ['Hardware', 'Energy', 'EE'],
                  image: 'lumindt.png',
                  url: 'https://lumindt.com',
                  class: 'aspect-[3/2]',
                },
                {
                  title: 'Carkner Studio',
                  tags: ['Web Dev', 'Agency'],
                  image: 'carkner-studio.png',
                  url: 'https://carkner.studio',
                  class: 'aspect-[3/2]',
                },
                {
                  title: 'BloodBox',
                  tags: ['Hardware', 'ML', 'MedTech'],
                  image: 'bloodbox.jpg',
                  url: 'https://bloodbox.info',
                },
                {
                  title: 'Research',
                  tags: ['Economics', 'Genomics', 'AI'],
                  image: 'research.jpeg',
                  url: '/blog/research',
                  class: 'aspect-[3/2]',
                },
                {
                  title: 'BattleBot',
                  tags: ['Hardware', 'Robotics'],
                  image: 'bot.jpeg',
                  url: '',
                },
              ].map((item, i) => (
                <div
                  id={`project-${i}`}
                  class:list={[i < 3 ? 'visible' : 'hidden']}
                >
                  <Project
                    title={item.title}
                    tags={item.tags}
                    image={'projects/' + item.image}
                    url={item.url}
                    class={item.class}
                  />
                </div>
              ))
            }
          </div>

          <button
            type="button"
            class="text-white font-mono font-bold bg-transparent border-none p-0 text-base text-left w-fit hover:text-sky-400 hover:cursor-pointer hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-400 rounded"
            id="more-projects"
            aria-expanded="false"
          >
            view all work
          </button>
          <script>
            const moreProjects = document.getElementById('more-projects')!
            const projects = document.querySelectorAll('[id^="project-"]')
            let hidden = true
            moreProjects.addEventListener('click', () => {
              hidden = !hidden
              projects.forEach((project, i) => {
                if (i < 3) return

                project.classList.toggle('visible', !hidden)
                project.classList.toggle('hidden', hidden)
              })
              moreProjects.setAttribute('aria-expanded', String(!hidden))
              moreProjects.innerText = hidden
                ? 'view all work'
                : 'view less work'
            })
          </script>
        </Card>
        <!--PHOTOS -->
        <Card>
          <div class="space-y-4">
            <!-- <h4>Photos</h4> -->
            <div
              class="flex flex-row space-x-2 md:space-x-4 items-center justify-center"
            >
              {
                [
                  {
                    img: 'cool-photos/beach.jpeg',
                    alt: 'Italian Beach',
                  },
                  {
                    img: 'cool-photos/city.jpeg',
                    alt: 'Matera',
                  },
                  {
                    img: 'cool-photos/town.jpeg',
                    alt: 'Italian town',
                  },
                ].map((item) => (
                  <img
                    alt={item.alt}
                    class="w-20 h-30 sm:w-40 sm:h-32 border border-gray-600 rounded-lg"
                    src={item.img}
                  />
                ))
              }
            </div>
            <div>
              <a
                class="text-white font-mono font-bold no-underline hover:text-sky-400 text-base hover:underline"
                href="/photos"
              >
                view my photos
              </a>
            </div>
          </div>
        </Card>

        <!-- Reading -->
        <Card class="space-y-4">
          <div class="relative">
            <div class="flex flex-row items-end justify-center gap-[2px] h-36 px-2 mb-0">
              {
                [
                  { title: 'American Prometheus', author: 'Kai Bird', color: 'bg-amber-900/80', accent: 'bg-amber-700/40', h: 'h-[8.5rem]', w: 'w-10' },
                  { title: "Astronaut's Guide", author: 'Chris Hadfield', color: 'bg-slate-700', accent: 'bg-slate-500/40', h: 'h-[8rem]', w: 'w-9' },
                  { title: "Plutarch's Lives", author: 'Plutarch', color: 'bg-rose-950', accent: 'bg-rose-800/40', h: 'h-[8.8rem]', w: 'w-8' },
                  { title: 'Sapiens', author: 'Yuval Noah Harari', color: 'bg-teal-900', accent: 'bg-teal-700/40', h: 'h-[8.8rem]', w: 'w-10' },
                  { title: '0 to 1', author: 'Peter Thiel', color: 'bg-indigo-950', accent: 'bg-indigo-800/40', h: 'h-[7.5rem]', w: 'w-8' },
                  { title: 'Atomic Habits', author: 'James Clear', color: 'bg-amber-950', accent: 'bg-amber-800/40', h: 'h-[8.6rem]', w: 'w-10' },
                  { title: 'Long Walk to Freedom', author: 'Nelson Mandela', color: 'bg-emerald-950', accent: 'bg-emerald-800/40', h: 'h-[8.8rem]', w: 'w-9' },
                  { title: 'Meditations', author: 'Marcus Aurelius', color: 'bg-stone-700', accent: 'bg-stone-500/40', h: 'h-[8.4rem]', w: 'w-8' },
                  { title: 'Ego is the Enemy', author: 'Ryan Holiday', color: 'bg-orange-950', accent: 'bg-orange-800/40', h: 'h-[8rem]', w: 'w-9' },
                  { title: 'Digital Minimalism', author: 'Cal Newport', color: 'bg-sky-950', accent: 'bg-sky-800/40', h: 'h-[8.5rem]', w: 'w-8' },
                ].map((book) => (
                  <div
                    class:list={[
                      book.h, book.w,
                      'relative group/book shrink-0 hover:-translate-y-2 duration-300 cursor-default',
                    ]}
                  >
                    <div class:list={[book.color, 'absolute inset-0 rounded-r-[3px] rounded-l-[1px] overflow-hidden']}>
                      <div class:list={[book.accent, 'absolute left-0 top-0 bottom-0 w-[3px]']} />
                      <div class="absolute top-1 left-0 right-0 h-[1px] bg-white/10" />
                      <div class="absolute bottom-1 left-0 right-0 h-[1px] bg-white/10" />
                    </div>
                    <p class="absolute inset-0 flex items-center justify-center font-mono text-[7px] text-white/60 [writing-mode:vertical-rl] rotate-180 overflow-hidden leading-tight px-[2px]">
                      {book.title}
                    </p>
                    <div class="absolute -top-14 left-1/2 -translate-x-1/2 opacity-0 group-hover/book:opacity-100 transition-opacity duration-200 bg-gray-900 border border-gray-600 rounded-md px-2 py-1 whitespace-nowrap z-50 pointer-events-none">
                      <p class="text-xs font-mono text-white">{book.title}</p>
                      <p class="text-xs font-mono text-gray-400">{book.author}</p>
                    </div>
                  </div>
                ))
              }
            </div>
            <div class="w-full h-[4px] bg-gradient-to-b from-gray-500 to-gray-700 rounded-sm shadow-md" />
          </div>
          <a
            class="text-white font-mono font-bold no-underline hover:text-sky-400 text-base hover:underline"
            href="/blog/reading"
          >
            view my notes
          </a>
        </Card>

        <!-- Quote-->
        <Card>
          <div class="space-y-2">
            <p class="text-gray-400 font-mono bold-slate-p text-left">
              Fall in love and <b>stay in love</b>. Explode. Don't
              intellectualize. Get passionate about ideas. Cram your head full
              of images. Stay in the library. Stay off the internet and all that
              crap. <b>Read all the great books</b>. Read all the great poetry.
              See all the great films. Fill your life with metaphors. <b
                >And then explode.</b
              >
            </p>
            <div class="flex flex-row space-x-2">
              <p class="text-gray-400 font-mono">- ray bradbury</p>
            </div>
          </div>
        </Card>

        <Card>
          <div class="space-y-2">
            <div class="relative group">
              <img
                id="art-image"
                alt={artData.text}
                class="w-full h-full border border-gray-600 rounded-lg hover:cursor-zoom-in"
                src={artData.imageUrl}
              />
              <button
                id="open-art-modal"
                aria-label="View full screen"
                class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-black/40 hover:bg-black/60 text-white rounded-md px-2 py-1 text-sm"
              >
                <span class="-translate-y-50">⤢</span>
              </button>
            </div>

            <div
              id="art-modal"
              class="fixed -top-3 left-0 w-screen h-screen bg-black/95 hidden opacity-0 transition-opacity duration-200 items-center justify-center z-50"
              role="dialog"
              aria-modal="true"
              aria-labelledby="art-modal-title"
              aria-hidden="true"
            >
              <h2 id="art-modal-title" class="sr-only">Full-screen artwork</h2>
              <button
                id="close-art-modal"
                aria-label="Close full-screen artwork"
                class="absolute top-4 right-4 text-white/70 hover:text-white text-3xl focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-400 rounded"
              >
                ×
              </button>
              <img
                alt={artData.text}
                src={artData.imageUrl}
                class="max-w-[90vw] max-h-[90vh] rounded-lg border border-gray-700"
              />
            </div>

            <script>
              const openBtn = document.getElementById('open-art-modal')!
              const modal = document.getElementById('art-modal')!
              const closeBtn = document.getElementById('close-art-modal')!
              let lastFocused: HTMLElement | null = null

              const openModal = () => {
                lastFocused = document.activeElement as HTMLElement
                modal.classList.remove('hidden')
                modal.classList.add('flex')
                modal.setAttribute('aria-hidden', 'false')
                requestAnimationFrame(() => {
                  modal.classList.add('opacity-100')
                  modal.classList.remove('opacity-0')
                  closeBtn.focus()
                })
                document.documentElement.classList.add('overflow-hidden')
              }
              const closeModal = () => {
                modal.classList.add('opacity-0')
                modal.classList.remove('opacity-100')
                const onEnd = (e: TransitionEvent) => {
                  if (e.target !== modal) return
                  modal.removeEventListener('transitionend', onEnd)
                  modal.classList.add('hidden')
                  modal.classList.remove('flex')
                  modal.setAttribute('aria-hidden', 'true')
                  document.documentElement.classList.remove('overflow-hidden')
                  lastFocused?.focus()
                }
                modal.addEventListener('transitionend', onEnd)
              }

              openBtn.addEventListener('click', (e) => {
                e.stopPropagation()
                openModal()
              })
              closeBtn.addEventListener('click', (e) => {
                e.stopPropagation()
                closeModal()
              })
              modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal()
              })
              document.addEventListener('keydown', (e) => {
                if (
                  e.key === 'Escape' &&
                  !modal.classList.contains('hidden')
                ) {
                  closeModal()
                }
              })
            </script>

            <div
              class="flex flex-col items-center justify-center text-center space-y-1"
            >
              <p class="text-white font-mono">{artTitle}</p>
              <p class="text-gray-400 font-mono text-sm">{artArtist}</p>
              <p class="text-gray-400 font-mono pt-1">{lastUpdated}</p>
              <a
                class="text-white font-mono font-bold no-underline hover:text-sky-400 text-base hover:underline"
                href="/art"
              >
                view archive
              </a>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </Section>
</Layout>
