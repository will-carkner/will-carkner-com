import Layout from '../layouts/Layout.astro'

// Generate a human-readable alt from a photo's filename.
// Falls back to a generic year-based description when the filename
// is just an IMG_#### or UUID pattern.
function altFrom(path: string, year: string, index: number): string {
  const file = path.split('/').pop() ?? ''
  const base = file.replace(/\.[a-z]+$/i, '')
  const isGeneric =
    /^IMG[_-]/i.test(base) ||
    /^\d+$/.test(base) ||
    /^[0-9a-f-]{20,}$/i.test(base)
  if (isGeneric) return `Photo ${index + 1} from ${year}`
  // Replace separators with spaces and capitalize
  const pretty = base.replace(/[-_]+/g, ' ').trim()
  return `${pretty.charAt(0).toUpperCase()}${pretty.slice(1)} (${year})`
}

