---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import Layout from '../layouts/Layout.astro'

// Bulk-import every photo under src/assets/cool-photos so Astro can
// optimize them at build time (responsive srcsets + AVIF/WebP).
const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/cool-photos/**/*.{jpeg,jpg,png,JPEG,JPG,PNG}',
  { eager: true },
)

// Resolve a shorthand key (filename or `2025/IMG_xxx.jpeg`) to an ImageMetadata.
function pic(key: string): ImageMetadata {
  const match = Object.entries(photoModules).find(([path]) =>
    path.endsWith(`/cool-photos/${key}`),
  )
  if (!match) throw new Error(`photo not found: ${key}`)
  return match[1].default
}

// Generate a human-readable alt from a photo's filename.
function altFrom(key: string, year: string, index: number): string {
  const file = key.split('/').pop() ?? ''
  const base = file.replace(/\.[a-z]+$/i, '')
  const isGeneric =
    /^IMG[_-]/i.test(base) ||
    /^\d+$/.test(base) ||
    /^[0-9a-f-]{20,}$/i.test(base)
  if (isGeneric) return `Photo ${index + 1} from ${year}`
  const pretty = base.replace(/[-_]+/g, ' ').trim()
  return `${pretty.charAt(0).toUpperCase()}${pretty.slice(1)} (${year})`
}

type Year = { year: string; columns: string[][] }

