---

<Layout
  show={true}
  title="Photos | Will Carkner"
  description="A collection of photos Will Carkner has taken over the years."
>
  <h1 class="sr-only">Photos</h1>
  {
    years.map(({ year, columns }, yearIdx) => (
      <>
        <h2 class="pt-3">{year}</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl py-4">
          {columns.map((images) => (
            <div class="grid gap-4">
              {images.map((key, i) => (
                <div>
                  <Image
                    class="h-auto max-w-full rounded-lg"
                    src={pic(key)}
                    alt={altFrom(key, year, i)}
                    widths={[240, 480, 720]}
                    sizes="(max-width: 768px) 50vw, 25vw"
                    loading={yearIdx === 0 && i < 2 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
              ))}
            </div>
          ))}
        </div>
      </>
    ))
  }
</Layout>
