---
export interface Props {
  title: string
  description?: string
  image?: string
  show?: boolean
  noindex?: boolean
}

const {
  title,
  description = 'Will Carkner — personal site, blog, photos, and projects.',
  image = '/will-c.jpg',
  show,
  noindex = false,
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString()
const socialImage = new URL(image, Astro.site).toString()

import Nav from '../components/Nav.astro'
import TopBanner from '../components/TopBanner.astro'
---

<!doctype html>
<html
  lang="en"
  class="min-h-screen text-white font-light selection:bg-transparent selection:text-sky-400"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="Will Carkner" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
  </head>
  <body class="flex flex-col justify-between items-center">
    <>
      <TopBanner />
      <slot />
      <div class="my-2">
        {show && <Nav />}
        <p class="text-gray-400 font-mono mb-4 text-sm mt-4">
          &copy {new Date().getFullYear()} WiLL CARKNER
        </p>
      </div>
    </>
  </body>

  <style is:global>
    @tailwind base;
    @tailwind components;
    @tailwind utilities;

    @layer base {
      h1 {
        @apply text-5xl font-bold sm:text-6xl;
      }
      h2 {
        @apply text-4xl font-bold sm:text-5xl;
      }
      h3 {
        @apply text-3xl font-bold sm:text-4xl;
      }
      h4 {
        @apply text-2xl font-bold sm:text-3xl;
      }

      html,
      body {
        @apply min-h-screen w-full bg-black text-center;
      }
      a {
        @apply underline decoration-2 underline-offset-1 duration-300;
      }
      a:hover {
        @apply underline-offset-4;
      }
      .bold-slate-p b {
        @apply text-slate-300;
        @apply font-medium;
      }
    }
  </style>
</html>
